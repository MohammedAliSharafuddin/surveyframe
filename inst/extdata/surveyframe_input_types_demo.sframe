{
  "hash": {
    "algo": "sha256",
    "value": "2283401c79649815436f588796623473fe5fc21491e14ced2a447f4594922d0c"
  },
  "version": "0.3.0",
  "meta": {
    "title": "Surveyframe Demo: Survey Title",
    "version": "0.3.0",
    "description": "Simulated questionnaire covering section breaks, text blocks, text, textarea, single choice, multiple choice, numeric, date, Likert, matrix, slider, ranking, rating, branching, attention checks, scored scales, and analysis plans.",
    "authors": "Mohammed Ali Sharafuddin",
    "languages": "en",
    "validated": true,
    "created_at": "2026-05-14T14:52:22Z"
  },
  "items": [
    {
      "id": "sec_intro",
      "label": "Section 1: Visit background",
      "type": "section_break",
      "required": false,
      "reverse": false,
      "section_intro": "A few questions about your visit and how you planned it.",
      "page": 1
    },
    {
      "id": "info_block",
      "label": "This is a display text block. It should not be treated as a response variable.",
      "type": "text_block",
      "required": false,
      "reverse": false,
      "page": 1
    },
    {
      "id": "respondent_name",
      "label": "Respondent display name",
      "type": "text",
      "required": false,
      "reverse": false,
      "placeholder": "Optional short name",
      "page": 1
    },
    {
      "id": "visit_type",
      "label": "Was this your first visit?",
      "type": "single_choice",
      "required": true,
      "choice_set": "visit_type",
      "reverse": false,
      "page": 1
    },
    {
      "id": "visit_purpose",
      "label": "What was the main purpose of your visit?",
      "type": "single_choice",
      "required": true,
      "choice_set": "visit_purpose",
      "reverse": false,
      "page": 1
    },
    {
      "id": "other_purpose",
      "label": "Please specify the other purpose.",
      "type": "text",
      "required": false,
      "reverse": false,
      "placeholder": "Write the other purpose",
      "page": 1
    },
    {
      "id": "information_channels",
      "label": "Which channels helped you before the visit?",
      "type": "multiple_choice",
      "required": true,
      "choice_set": "channels",
      "reverse": false,
      "help": "Select all that apply.",
      "page": 1
    },
    {
      "id": "booking_date",
      "label": "When did you make the booking?",
      "type": "date",
      "required": true,
      "reverse": false,
      "page": 1
    },
    {
      "id": "nights_stayed",
      "label": "How many nights did you stay?",
      "type": "numeric",
      "required": true,
      "reverse": false,
      "help": "Enter the number of nights.",
      "page": 1,
      "slider_min": 0,
      "slider_max": 365
    },
    {
      "id": "sec_experience",
      "label": "Section 2: Experience and service ratings",
      "type": "section_break",
      "required": false,
      "reverse": false,
      "section_intro": "Tell us how you rate the digital information and the service you received.",
      "page": 2
    },
    {
      "id": "digital_ease",
      "label": "Online information made the visit easier to plan.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "digital_experience",
      "reverse": false,
      "page": 2
    },
    {
      "id": "digital_trust",
      "label": "The online information appeared trustworthy.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "digital_experience",
      "reverse": false,
      "page": 2
    },
    {
      "id": "digital_confusion",
      "label": "Online information made the planning process confusing.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "digital_experience",
      "reverse": true,
      "page": 2
    },
    {
      "id": "service_matrix",
      "label": "Please rate the following service aspects.",
      "type": "matrix",
      "required": true,
      "choice_set": "agree5",
      "reverse": false,
      "matrix_items": ["Cleanliness", "Staff helpfulness", "Food quality", "Transport support"],
      "page": 2
    },
    {
      "id": "value_slider",
      "label": "How would you rate value for money?",
      "type": "slider",
      "required": true,
      "reverse": false,
      "slider_min": 0,
      "slider_max": 100,
      "slider_step": 5,
      "page": 2
    },
    {
      "id": "feature_ranking",
      "label": "Rank the following features by importance.",
      "type": "ranking",
      "required": true,
      "choice_set": "feature_rank",
      "reverse": false,
      "page": 2
    },
    {
      "id": "overall_rating",
      "label": "Overall experience rating",
      "type": "rating",
      "required": true,
      "reverse": false,
      "rating_max": 5,
      "rating_icon": "star",
      "page": 2
    },
    {
      "id": "sec_feedback",
      "label": "Section 3: Intentions and feedback",
      "type": "section_break",
      "required": false,
      "reverse": false,
      "section_intro": "Your future intentions, a quick check, and any final comments.",
      "page": 3
    },
    {
      "id": "recommend",
      "label": "I would recommend this service to others.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "behavioural_intention",
      "reverse": false,
      "page": 3
    },
    {
      "id": "reuse",
      "label": "I would use a similar service again.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "behavioural_intention",
      "reverse": false,
      "page": 3
    },
    {
      "id": "attention",
      "label": "For quality control, please select Agree.",
      "type": "single_choice",
      "required": true,
      "choice_set": "agree5",
      "reverse": false,
      "page": 3
    },
    {
      "id": "follow_up_permission",
      "label": "May the research team contact you for clarification?",
      "type": "single_choice",
      "required": true,
      "choice_set": "yes_no",
      "reverse": false,
      "page": 3
    },
    {
      "id": "open_comment",
      "label": "Please add any comments about your visit.",
      "type": "textarea",
      "required": false,
      "reverse": false,
      "placeholder": "Optional comment",
      "page": 3
    }
  ],
  "choices": [
    {
      "id": "agree5",
      "values": [1, 2, 3, 4, 5],
      "labels": ["Strongly disagree", "Disagree", "Neither agree nor disagree", "Agree", "Strongly agree"],
      "allow_other": false,
      "randomise": false
    },
    {
      "id": "visit_type",
      "values": ["first_time", "repeat"],
      "labels": ["First-time visitor", "Repeat visitor"],
      "allow_other": false,
      "randomise": false
    },
    {
      "id": "visit_purpose",
      "values": ["holiday", "business", "family", "education", "other"],
      "labels": ["Holiday", "Business", "Family visit", "Education", "Other"],
      "allow_other": false,
      "randomise": false
    },
    {
      "id": "channels",
      "values": ["search_engine", "instagram", "facebook", "youtube", "travel_blog", "friend"],
      "labels": ["Search engine", "Instagram", "Facebook", "YouTube", "Travel blog", "Friend or family"],
      "allow_other": false,
      "randomise": false
    },
    {
      "id": "yes_no",
      "values": ["yes", "no"],
      "labels": ["Yes", "No"],
      "allow_other": false,
      "randomise": false
    },
    {
      "id": "feature_rank",
      "values": ["service_quality", "price", "sustainability", "location", "digital_information"],
      "labels": ["Service quality", "Price", "Sustainability", "Location", "Digital information"],
      "allow_other": false,
      "randomise": false
    }
  ],
  "scales": [
    {
      "id": "digital_experience",
      "label": "Digital experience",
      "items": ["digital_ease", "digital_trust", "digital_confusion"],
      "method": "mean",
      "min_valid": 2,
      "reverse_items": "digital_confusion"
    },
    {
      "id": "behavioural_intention",
      "label": "Behavioural intention",
      "items": ["recommend", "reuse"],
      "method": "mean",
      "min_valid": 2
    }
  ],
  "branching": [
    {
      "item_id": "other_purpose",
      "depends_on": "visit_purpose",
      "operator": "==",
      "value": "other",
      "action": "show"
    }
  ],
  "checks": [
    {
      "id": "attention_agree",
      "item_id": "attention",
      "type": "attention",
      "pass_values": 4,
      "fail_action": "flag",
      "label": "Instructional attention check",
      "notes": "Respondent should select Agree."
    }
  ],
  "analysis_plan": [
    {
      "id": "rq_digital_bi",
      "research_question": "Is digital experience associated with behavioural intention?",
      "family": "association",
      "method": "correlation_pearson",
      "test": "correlation_pearson",
      "roles": {
        "x": "digital_experience",
        "y": "behavioural_intention"
      },
      "variables": ["digital_experience", "behavioural_intention"],
      "options": {
        "alpha": 0.05
      },
      "hypotheses": {
        "null": "Digital experience is not associated with behavioural intention.",
        "alternative": "Digital experience is associated with behavioural intention."
      },
      "decision_rule": "Report the direction, size, and uncertainty of the relationship.",
      "interpretation": "Report the direction, size, and uncertainty of the relationship.",
      "reporting_references": [],
      "citations": [],
      "status": "valid_plan",
      "requires_data": true,
      "alpha": 0.05
    },
    {
      "id": "rq_visit_rating",
      "research_question": "Do first-time and repeat visitors differ in overall rating?",
      "family": "group_comparison",
      "method": "mann_whitney",
      "test": "mann_whitney",
      "roles": {
        "group": "visit_type",
        "outcome": "overall_rating"
      },
      "variables": ["visit_type", "overall_rating"],
      "options": {
        "alpha": 0.05
      },
      "hypotheses": {
        "null": "First-time and repeat visitors do not differ in overall rating.",
        "alternative": "First-time and repeat visitors differ in overall rating."
      },
      "decision_rule": "Compare the distribution of ratings across visitor groups.",
      "interpretation": "Compare the distribution of ratings across visitor groups.",
      "reporting_references": [],
      "citations": [],
      "status": "valid_plan",
      "requires_data": true,
      "alpha": 0.05
    },
    {
      "id": "rq_freq",
      "research_question": "What is the distribution of visit purposes in the sample?",
      "variables": "visit_purpose",
      "test": "frequency",
      "method": "frequency",
      "alpha": 0.05,
      "family": "descriptive",
      "roles": [],
      "options": [],
      "decision_rule": "Report absolute and relative frequencies for each category.",
      "interpretation": "Report absolute and relative frequencies for each category.",
      "citations": [],
      "reporting_references": [],
      "status": "valid_plan",
      "requires_data": true
    },
    {
      "id": "rq_desc",
      "research_question": "What are the central tendency and spread of all Likert and rating items?",
      "variables": ["digital_ease", "digital_trust", "digital_confusion", "recommend", "reuse", "overall_rating"],
      "test": "descriptives",
      "method": "descriptives",
      "alpha": 0.05,
      "family": "descriptive",
      "roles": [],
      "options": [],
      "decision_rule": "Inspect mean, SD, skewness, and kurtosis for each item.",
      "interpretation": "Inspect mean, SD, skewness, and kurtosis for each item.",
      "citations": [],
      "reporting_references": [],
      "status": "valid_plan",
      "requires_data": true
    },
    {
      "id": "rq_missing",
      "research_question": "What is the pattern of missing responses across items?",
      "variables": ["digital_ease", "digital_trust", "digital_confusion", "recommend", "reuse", "overall_rating", "nights_stayed"],
      "test": "missing_data",
      "method": "missing_data",
      "alpha": 0.05,
      "family": "descriptive",
      "roles": [],
      "options": [],
      "decision_rule": "Flag items with more than 10 per cent missing.",
      "interpretation": "Flag items with more than 10 per cent missing.",
      "citations": [],
      "reporting_references": [],
      "status": "valid_plan",
      "requires_data": true
    },
