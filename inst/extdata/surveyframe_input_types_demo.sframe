    {
      "id": "rq_efa_ready",
      "research_question": "Does the inter-item correlation matrix support exploratory factor analysis?",
      "variables": ["digital_ease", "digital_trust", "digital_confusion", "recommend", "reuse"],
      "test": "efa_readiness",
      "method": "efa_readiness",
      "alpha": 0.05,
