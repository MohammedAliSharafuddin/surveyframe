    {
      "id": "rq_efa_sol",
      "research_question": "How many factors emerge from digital experience and behavioural intention items?",
      "variables": ["digital_ease", "digital_trust", "digital_confusion", "recommend", "reuse"],
      "test": "efa_solution",
