  "analysis_plan": [
    {
      "id": "rq_dm_sat",
      "research_question": "Is perceived digital marketing effectiveness associated with tourist satisfaction?",
      "variables": ["digital_marketing", "satisfaction"],
      "test": "correlation_pearson",
      "alpha": 0.05,
      "interpretation": "Use the direction and size of the correlation to describe the relationship."
    },
    {
      "id": "rq_predict_sat",
      "research_question": "Do digital marketing, service quality, and sustainability perceptions predict satisfaction?",
      "variables": ["digital_marketing", "service_quality", "sustainability", "satisfaction"],
      "test": "regression_linear",
      "alpha": 0.05,
      "interpretation": "Compare the regression coefficients to identify the strongest predictor."
    },
    {
      "id": "rq_visit_bi",
      "research_question": "Do first-time and repeat visitors differ in behavioural intention?",
      "variables": ["visit_type", "behavioural_intention"],
      "test": "mann_whitney",
      "alpha": 0.05,
      "interpretation": "Report whether behavioural intention differs by visitor type."
    }
  ],
