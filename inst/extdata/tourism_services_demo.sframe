  "version": "0.3.0",
  "meta": {
    "title": "Tourism Services Experience Demo",
    "version": "0.3.0",
    "description": "Simulated demo questionnaire inspired by tourism-services research on digital marketing, service quality, sustainability, satisfaction, and behavioural intention.",
    "authors": "Mohammed Ali Sharafuddin",
    "languages": "en",
    "validated": true,
    "created_at": "2026-05-13T18:16:19Z"
  },
  "items": [
    {
      "id": "visit_type",
      "label": "Visitor type",
      "type": "single_choice",
      "required": true,
      "choice_set": "visit_type",
      "reverse": false
    },
    {
      "id": "dm_1",
      "label": "Digital content helped me discover tourism services.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "digital_marketing",
      "reverse": false
    },
    {
      "id": "dm_2",
      "label": "Social media information was useful for planning my visit.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "digital_marketing",
      "reverse": false
    },
    {
      "id": "dm_3",
      "label": "Online promotions improved my interest in the destination.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "digital_marketing",
      "reverse": false
    },
    {
      "id": "sq_1",
      "label": "Tourism staff provided reliable service.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "service_quality",
      "reverse": false
    },
    {
      "id": "sq_2",
      "label": "The service environment was easy to navigate.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "service_quality",
      "reverse": false
    },
    {
      "id": "sq_3",
      "label": "The tourism service met my expectations.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "service_quality",
      "reverse": false
    },
    {
      "id": "sus_1",
      "label": "The tourism provider communicated sustainability practices clearly.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "sustainability",
      "reverse": false
    },
    {
      "id": "sus_2",
      "label": "The visit encouraged responsible tourism behaviour.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "sustainability",
      "reverse": false
    },
    {
      "id": "sat_1",
      "label": "Overall, I was satisfied with the tourism experience.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "satisfaction",
      "reverse": false
    },
    {
      "id": "sat_2",
      "label": "The experience was worth the time and cost.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "satisfaction",
      "reverse": false
    },
    {
      "id": "bi_1",
      "label": "I would recommend this tourism service to others.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "behavioural_intention",
      "reverse": false
    },
    {
      "id": "bi_2",
      "label": "I intend to use similar tourism services again.",
      "type": "likert",
      "required": true,
      "choice_set": "agree5",
      "scale_id": "behavioural_intention",
      "reverse": false
    },
    {
      "id": "attention",
      "label": "For quality control, please select Agree.",
      "type": "single_choice",
      "required": true,
      "choice_set": "agree5",
      "reverse": false
    },
    {
      "id": "comments",
      "label": "Optional comments about the tourism experience.",
      "type": "textarea",
      "required": false,
      "reverse": false
    }
  ],
  "choices": [
    {
      "id": "agree5",
      "values": [1, 2, 3, 4, 5],
      "labels": ["Strongly disagree", "Disagree", "Neither agree nor disagree", "Agree", "Strongly agree"],
      "allow_other": false,
      "randomise": false
    },
    {
      "id": "visit_type",
      "values": ["first_time", "repeat"],
      "labels": ["First-time visitor", "Repeat visitor"],
      "allow_other": false,
      "randomise": false
    },
    {
      "id": "yes_no",
      "values": ["yes", "no"],
      "labels": ["Yes", "No"],
      "allow_other": false,
      "randomise": false
    }
  ],
