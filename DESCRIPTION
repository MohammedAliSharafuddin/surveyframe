Package: surveyframe
Title: Survey Instrument Workflows
Version: 0.3.3
Authors@R: c(
    person(
      given = "Mohammed Ali",
      family = "Sharafuddin",
      email = "mohammedali.page@gmail.com",
      role = c("aut", "cre"),
      comment = c(ORCID = "0000-0001-5247-2964")
    )
